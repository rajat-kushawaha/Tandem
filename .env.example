# ---------------------------------------------------------------------------
# Agentic SDLC — environment configuration
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real secrets.
# Config is validated once at startup (src/shared/config.ts) and fails fast.
# ---------------------------------------------------------------------------

# --- Claude auth (provide exactly ONE; the OAuth token is preferred) ---
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# --- Per-agent models (override the defaults if needed) ---
BA_MODEL=claude-sonnet-4-6
DEV_MODEL=claude-opus-4-8
REVIEWER_MODEL=claude-opus-4-8

# --- Jira (Atlassian Rovo MCP + REST, API-token auth for headless use) ---
JIRA_SITE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
# JQL selecting tickets to ingest; the poller maps status -> orchestrator event.
JIRA_JQL=project = AGENT ORDER BY updated DESC
JIRA_POLL_INTERVAL_MS=30000
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp

# Jira status names — match your board EXACTLY (case-sensitive on some boards).
# BA ingests from BACKLOG; Dev ingests from IN_PROGRESS (a human moves it there).
# PR-open -> IN_REVIEW; reviewer approval -> READY_FOR_MERGE (human merge gate).
JIRA_STATUS_BACKLOG=Backlog
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_IN_REVIEW=QA
JIRA_STATUS_READY_FOR_MERGE=In PR review
# Optional: where the ticket goes once every PR is merged. Leave unset to mark
# the ticket DONE internally (with a Jira comment) but leave the column alone.
# JIRA_STATUS_DONE=Done

# --- Slack (a Socket Mode app: bot token + app-level token + channel) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789

# --- GitHub: dev identity (PAT used to clone, push, and open PRs) ---
# Needs repo (contents + pull_requests) scope. NOT granted merge; protect main.
GITHUB_TOKEN=ghp_your_dev_pat
# Optional second-account PAT the reviewer uses to APPROVE (GitHub forbids
# self-approval). If left empty, the reviewer posts an approval comment instead.
# Not named GITHUB_*: GitHub Actions reserves that prefix for secret names, so
# the same name is used here and as the repo secret.
REVIEWER_GITHUB_TOKEN=
# Repo routing map. Keywords (matched against the ticket text) decide which
# repos a ticket affects. Format:
#   key:owner/repo:kw1,kw2;key2:owner/repo2:kw1,kw2
GITHUB_REPOS=api:your-org/backend:api,backend,server;ui:your-org/frontend:ui,frontend,react
GITHUB_BASE_BRANCH=main

# Disposable per-ticket checkout root. Defaults to a temp dir; MUST be outside
# this project tree so the agent's gates (eslint/tsc/prettier/vitest) don't
# inherit THIS repo's config via ancestor lookup. Uncomment only to override.
# SANDBOX_ROOT=/tmp/agentic-sdlc-sandbox

# Persist per-ticket state to a JSON file so a restart resumes in-flight tickets
# (single-process only). Unset = in-memory (state lost on restart). Recommended
# for local/demo runs; production uses a Mongo/Redis store instead.
RUN_STORE_FILE=.run-store.json

# --- Per-ticket budget (a confused run can't loop forever or burn the pool) ---
# MAX_TURNS_PER_RUN caps a single agent invocation; MAX_TURNS_PER_TICKET is the
# cumulative ceiling across every attempt and repo of one ticket.
MAX_TURNS_PER_RUN=150
MAX_TURNS_PER_TICKET=500
MAX_TOKENS_PER_TICKET=3000000
MAX_WALL_CLOCK_MS=2400000
DEV_MAX_FIX_ATTEMPTS=4

# How long a ticket may sit unchanged in an agent-owned state before the
# watchdog re-triggers its workflow (self-healing after a crash or lost event).
# Must comfortably exceed the longest legitimate run. Default: 90 minutes.
WATCHDOG_STALE_MS=5400000

# --- Logging ---
LOG_LEVEL=info

# --- Inngest (persistent self-hosted mode: npm run start:inngest) ---
# Generate local-only keys (any hex): openssl rand -hex 16 / openssl rand -hex 32.
# The orchestrator SDK and the Inngest server must share them; BASE_URL points
# the SDK at the local server instead of Inngest Cloud. Omit all three to use
# the ephemeral dev mode (npm run dev:inngest) instead.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_BASE_URL=http://127.0.0.1:8288
